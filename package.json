{
  "name": "asset-helper",
  "description": "个人资产与多市场行情查看 Chrome 扩展",
  "private": true,
  "version": "1.0.2",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "export PATH=/usr/local/bin:$PATH; node scripts/patch-rollup-native.mjs && tsc --noEmit && vite build",
    "build:extension": "export PATH=/usr/local/bin:$PATH; node scripts/patch-rollup-native.mjs && tsc --noEmit && vite build",
    "build:store": "pnpm run build:extension && pnpm run obfuscate:dist",
    "dev": "export PATH=/usr/local/bin:$PATH; node scripts/patch-rollup-native.mjs && vite",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "postinstall": "node scripts/patch-rollup-native.mjs",
    "obfuscate:dist": "node scripts/obfuscate-dist.mjs"
  },
  "dependencies": {
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router": "7.13.0",
    "recharts": "2.15.2",
    "tw-animate-css": "1.3.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@rollup/wasm-node": "4.60.3",
    "@tailwindcss/vite": "4.1.12",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "4.7.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "javascript-obfuscator": "^5.4.3",
    "tailwindcss": "4.1.12",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vite": "6.3.5"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    },
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "lightningcss"
    ]
  }
}
