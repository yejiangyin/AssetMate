{
  "manifest_version": 3,
  "name": "资产助手",
  "version": "2.0.1",
  "version_name": "2.0.1",
  "description": "个人资产、多市场行情、AI 投研与策略回测插件。",
  "permissions": [
    "sidePanel",
    "storage",
    "alarms",
    "declarativeNetRequest"
  ],
  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "资产助手",
    "default_popup": "index.html",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "32":  "icons/icon-32.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "index.html?view=sidepanel"
  },
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "sec_request_identity",
        "enabled": true,
        "path": "rules/sec-request-identity.json"
      }
    ]
  },
  "host_permissions": [
    "https://query1.finance.yahoo.com/v8/finance/*",
    "https://query1.finance.yahoo.com/v1/finance/*",
    "https://query1.finance.yahoo.com/v1/test/*",
    "https://query1.finance.yahoo.com/v10/finance/*",
    "https://query2.finance.yahoo.com/v8/finance/*",
    "https://query2.finance.yahoo.com/v1/finance/*",
    "https://query2.finance.yahoo.com/v1/test/*",
    "https://query2.finance.yahoo.com/v10/finance/*",
    "https://fc.yahoo.com/*",
    "https://api.nasdaq.com/api/quote/*",
    "https://api.coingecko.com/api/v3/*",
    "https://searchapi.eastmoney.com/*",
    "https://push2delay.eastmoney.com/api/*",
    "https://push2his.eastmoney.com/api/*",
    "https://fundsuggest.eastmoney.com/FundSearch/*",
    "https://fundf10.eastmoney.com/*",
    "https://api.fund.eastmoney.com/f10/*",
    "https://fund.eastmoney.com/pingzhongdata/*",
    "https://fundgz.1234567.com.cn/js/*",
    "https://datacenter-web.eastmoney.com/api/*",
    "https://qt.gtimg.cn/*",
    "https://web.ifzq.gtimg.cn/appstock/*",
    "https://open.er-api.com/v6/*",
    "https://api.binance.com/api/v3/*",
    "https://www.okx.com/api/v5/*",
    "https://api.tavily.com/*",
    "https://api.search.brave.com/*",
    "https://api.exa.ai/*",
    "https://open.feedcoopapi.com/*",
    "https://datapro.hqd.cn-beijing.volces.com/*",
    "https://data.sec.gov/*",
    "https://www.sec.gov/*"
  ],
  "optional_host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*/*"
  ]
}
